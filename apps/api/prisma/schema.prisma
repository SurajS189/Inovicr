// This is the FULL database schema for Invoicr
// Run: npx prisma migrate dev --name init
// Run: npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
// TENANTS (each business is a tenant)
// ═══════════════════════════════════════════════
model Tenant {
  id            String   @id @default(uuid())
  name          String
  email         String
  logoUrl       String?
  address       String?
  gstNumber     String?
  invoicePrefix String   @default("INV")
  currency      String   @default("INR")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  users     TenantUser[]
  clients   Client[]
  invoices  Invoice[]
  expenses  Expense[]
  invites   Invite[]

  @@map("tenants")
}

// ═══════════════════════════════════════════════
// USERS
// ═══════════════════════════════════════════════
model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String?   // null for OAuth users
  name           String
  avatarUrl      String?
  googleId       String?   @unique
  emailVerified  Boolean   @default(false)
  verifyToken    String?
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  tenants        TenantUser[]
  refreshTokens  RefreshToken[]
  notifications  Notification[]

  @@map("users")
}

// ═══════════════════════════════════════════════
// TENANT ↔ USER (many-to-many with roles)
// ═══════════════════════════════════════════════
model TenantUser {
  id        String     @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantRole @default(VIEWER)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

enum TenantRole {
  OWNER
  ACCOUNTANT
  VIEWER
}

// ═══════════════════════════════════════════════
// REFRESH TOKENS
// ═══════════════════════════════════════════════
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique // store hash, never plain token
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════
// INVITES
// ═══════════════════════════════════════════════
model Invite {
  id        String     @id @default(uuid())
  tenantId  String
  email     String
  role      TenantRole @default(VIEWER)
  token     String     @unique
  expiresAt DateTime
  accepted  Boolean    @default(false)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("invites")
}

// ═══════════════════════════════════════════════
// CLIENTS
// ═══════════════════════════════════════════════
model Client {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  address   String?
  gstNumber String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([tenantId])
  @@map("clients")
}

// ═══════════════════════════════════════════════
// INVOICES
// ═══════════════════════════════════════════════
model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  clientId       String
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime
  dueDate        DateTime
  notes          String?
  subtotal       Decimal       @db.Decimal(12, 2)
  taxAmount      Decimal       @db.Decimal(12, 2) @default(0)
  discountAmount Decimal       @db.Decimal(12, 2) @default(0)
  total          Decimal       @db.Decimal(12, 2)
  currency       String        @default("INR")
  pdfUrl         String?       // S3 URL after generation
  viewToken      String        @unique @default(uuid()) // public view URL token
  viewedAt       DateTime?
  paidAt         DateTime?
  paymentMethod  String?
  razorpayLinkId String?
  razorpayLinkUrl String?
  // Recurring
  isRecurring    Boolean       @default(false)
  recurringFreq  RecurringFreq?
  nextRunAt      DateTime?
  parentInvoiceId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client      @relation(fields: [clientId], references: [id])
  lineItems LineItem[]
  payments  Payment[]
  reminders ReminderLog[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum RecurringFreq {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ═══════════════════════════════════════════════
// LINE ITEMS
// ═══════════════════════════════════════════════
model LineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  taxPercent  Decimal @db.Decimal(5, 2) @default(0)
  discount    Decimal @db.Decimal(12, 2) @default(0)
  total       Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("line_items")
}

// ═══════════════════════════════════════════════
// PAYMENTS (manual + webhook)
// ═══════════════════════════════════════════════
model Payment {
  id            String   @id @default(uuid())
  invoiceId     String
  amount        Decimal  @db.Decimal(12, 2)
  method        String   // bank_transfer, razorpay, cash, cheque
  reference     String?  // UTR / transaction ID
  note          String?
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ═══════════════════════════════════════════════
// EXPENSES
// ═══════════════════════════════════════════════
model Expense {
  id           String   @id @default(uuid())
  tenantId     String
  description  String
  amount       Decimal  @db.Decimal(12, 2)
  category     String?  // AI-categorised or manual
  aiCategory   String?  // raw AI suggestion
  aiConfidence Float?   // 0-1 confidence score
  receiptUrl   String?  // S3 URL
  expenseDate  DateTime
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, expenseDate])
  @@map("expenses")
}

// ═══════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  metadata  Json?            // flexible: invoiceId, amount, etc.
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

enum NotificationType {
  INVOICE_VIEWED
  PAYMENT_RECEIVED
  INVOICE_OVERDUE
  REMINDER_SENT
  AI_INSIGHT
}

// ═══════════════════════════════════════════════
// REMINDER LOGS (track what reminders sent when)
// ═══════════════════════════════════════════════
model ReminderLog {
  id         String   @id @default(uuid())
  invoiceId  String
  sentAt     DateTime @default(now())
  type       String   // 3_days_before | due_today | 7_days_after
  emailTo    String

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("reminder_logs")
}
